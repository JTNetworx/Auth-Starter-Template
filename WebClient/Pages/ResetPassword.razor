@page "/reset-password"
@layout MainLayout
@inject IAuthApiService AuthApi
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Reset Password</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="3" Class="pa-8">
        @if (!_success)
        {
            <div class="text-center mb-6">
                <MudIcon Icon="@Icons.Material.Filled.LockReset" Color="Color.Primary" Style="font-size:3rem" />
                <MudText Typo="Typo.h5" Class="mt-2" Style="font-weight:600">Reset Password</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Enter your new password below.</MudText>
            </div>

            <EditForm Model="_model" OnValidSubmit="SubmitAsync">
                <DataAnnotationsValidator />

                <MudTextField Label="New Password"
                              @bind-Value="_model.NewPassword"
                              For="@(() => _model.NewPassword)"
                              Variant="Variant.Outlined"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              HelperText="Min 8 chars, upper, lower, digit & special char"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="@(() => _showPassword = !_showPassword)"
                              Class="mb-4"
                              Disabled="_loading" />

                <MudTextField Label="Confirm New Password"
                              @bind-Value="_model.ConfirmNewPassword"
                              For="@(() => _model.ConfirmNewPassword)"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Class="mb-4"
                              Disabled="_loading" />

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_errorMessage</MudAlert>
                }

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Disabled="_loading">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Resetting...</span>
                    }
                    else
                    {
                        <span>Reset Password</span>
                    }
                </MudButton>
            </EditForm>
        }
        else
        {
            <div class="text-center">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size:4rem" />
                <MudText Typo="Typo.h5" Class="mt-4" Style="font-weight:600">Password Reset!</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">
                    Your password has been reset successfully.
                </MudText>
                <MudButton Href="/login" Variant="Variant.Filled" Color="Color.Primary" Class="mt-6" Size="Size.Large">
                    Sign In
                </MudButton>
            </div>
        }
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private readonly ResetPasswordRequest _model = new();
    private bool _loading;
    private bool _showPassword;
    private bool _success;
    private string? _errorMessage;

    protected override void OnInitialized()
    {
        _model.Email = Email ?? string.Empty;
        _model.Token = Token ?? string.Empty;
    }

    private async Task SubmitAsync()
    {
        _loading = true;
        _errorMessage = null;

        var result = await AuthApi.ResetPasswordAsync(_model);
        _loading = false;

        if (!result.IsSuccess)
        {
            _errorMessage = result.Error ?? "Password reset failed. The link may have expired.";
            return;
        }

        _success = true;
    }
}
