@page "/forgot-password"
@layout MainLayout
@inject IAuthApiService AuthApi
@inject ISnackbar Snackbar

<PageTitle>Forgot Password</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="3" Class="pa-8">
        @if (!_emailSent)
        {
            <div class="text-center mb-6">
                <MudIcon Icon="@Icons.Material.Filled.LockReset" Color="Color.Primary" Style="font-size:3rem" />
                <MudText Typo="Typo.h5" Class="mt-2" Style="font-weight:600">Forgot Password?</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Enter your email and we'll send you a reset link.
                </MudText>
            </div>

            <EditForm Model="_model" OnValidSubmit="SubmitAsync">
                <DataAnnotationsValidator />

                <MudTextField Label="Email Address"
                              @bind-Value="_model.Email"
                              For="@(() => _model.Email)"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email"
                              Class="mb-4"
                              Disabled="_loading" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Disabled="_loading">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Sending...</span>
                    }
                    else
                    {
                        <span>Send Reset Link</span>
                    }
                </MudButton>
            </EditForm>
        }
        else
        {
            <div class="text-center">
                <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead" Color="Color.Success" Style="font-size:4rem" />
                <MudText Typo="Typo.h5" Class="mt-4" Style="font-weight:600">Check Your Email</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">
                    If that email is registered, you will receive a password reset link shortly.
                </MudText>
            </div>
        }

        <MudDivider Class="my-4" />
        <div class="text-center">
            <MudLink Href="/login" Color="Color.Primary" Typo="Typo.body2">Back to Sign In</MudLink>
        </div>
    </MudPaper>
</MudContainer>

@code {
    private readonly ForgotPasswordRequest _model = new();
    private bool _loading;
    private bool _emailSent;

    private async Task SubmitAsync()
    {
        _loading = true;
        await AuthApi.ForgotPasswordAsync(_model.Email);
        _loading = false;
        _emailSent = true;
    }
}
