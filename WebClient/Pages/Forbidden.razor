@page "/forbidden"
@layout MainLayout

<PageTitle>Access Denied</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16 text-center">
    <MudIcon Icon="@Icons.Material.Filled.Lock" Style="font-size:4rem" Color="Color.Error" />
    <MudText Typo="Typo.h4" Class="mt-4" Style="font-weight:600">Access Denied</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">
        You do not have permission to view this page.
    </MudText>
    <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-6">
        Go Home
    </MudButton>
</MudContainer>
