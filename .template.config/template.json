  "classifications": [
    "Web",
    "API",
    "Blazor",
    "Clean Architecture",
    "Authentication"
  ],
  "identity": "JTNetworx.AuthStarterTemplate.CSharp",
  "name": "ASP.NET Core Auth Starter",
  "shortName": "auth-starter",
  "description": "Full-stack auth starter: ASP.NET Core 10 API + Blazor WASM, Clean Architecture, JWT + refresh tokens, passkeys (WebAuthn), roles, admin panel, audit log, 2FA, GDPR, rate limiting, idempotency, correlation IDs, output caching, SignalR notifications, and localization.",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "sourceName": "AuthStarterTemplate",
  "preferNameDirectory": true,
  "primaryOutputs": [
    {
      "path": "AuthStarterTemplate.slnx"
    }
  ],
  "postActions": [
    {
      "id": "restore",
      "description": "Restore NuGet packages",
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    }
  ],
  "guids": [
    "ad7bbc53-294c-410d-bba2-305edd3f3a1e",
    "c1e491c6-de2c-4239-a785-e07e4a15226c"
  ],
  "sources": [
    {
      "source": "./",
      "target": "./",
      "exclude": [
        ".git/**",
        ".gitignore",
        ".vs/**",
        "**/.claude/**",
        "**/bin/**",
        "**/obj/**",
        "**/logs/**",
        "**/TestResults/**",
        "**/*.user",
        "**/*.suo",
        ".template.config/**",
        "assets/Icon.pdn",
        "pack/**",
        "release-artifacts/**",
        ".github/workflows/publish.yml"
      ]
    }
  ]
}
